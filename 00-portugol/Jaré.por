programa {
  funcao inicio() {
    inteiro jare
    real lucroPorCaminhao, lucroTotal
    real valorJare
    inteiro caminhao

    lucroPorCaminhao = (90*50) - 450

    escreva("Quantos caminhões? :")
    leia(caminhao)
    lucroTotal = lucroPorCaminhao * caminhao
    escreva("Lucro da Temporada: R$" + lucroTotal)


  }
}
